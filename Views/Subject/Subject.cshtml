@{
    ViewData["Title"] = "Subject";
}
<div style="border:5px solid;height:900px;width:900px;padding:20px;border-radius:5px;">

    <div style="border:2px solid;padding:15px; width:600px;margin:auto;border-radius:5px;">
        <form method="post">
            <center><h2 style="background-color:chartreuse">Subject Form</h2></center>

            <input type="hidden" id="Id" name="Id">

            <b><label>Code:</label><br><br></b>
            <input type="text" id="Code" name="Code" style="width:550px;height: 30px" required><br><br>

            <b><label>Name:</label><br><br></b>
            <input type="text" id="Name" name="Name" style="width:550px;height: 30px" required><br><br>

            <b><label>Credit Hours:</label><br><br></b>
            <input type="number" id="CreditHours" name="CreditHours" style="width:550px;height: 30px" required><br><br>

            <b><label>Type:</label><br><br></b>
            <input type="text" id="Type" name="Type" style="width:550px;height: 30px" required><br><br>

            <b><label>Description:</label><br><br></b>
            <textarea id="Description" name="Description" rows="4" cols="20" style="width:550px;"></textarea><br><br>

            <center>
                <button type="button" onclick="checkAction()" style="width:100px;height:30px;background:red;">
                    Submit
                </button><br><br>
            </center>
        </form>
    </div>

    <table id="SubjectTable" border="1" style="width:90%;margin:auto;text-align:center;border-collapse:collapse;">
        <thead>
            <tr style="background-color:lightgray;">
                <th>ID</th>
                <th>Code</th>
                <th>Name</th>
                <th>Credit Hours</th>
                <th>Type</th>
                <th>Description</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function AddSubject() {
            var Code = $("#Code").val();
            var Name = $("#Name").val();
            var CreditHours = $("#CreditHours").val();
            var Type = $("#Type").val();
            var Description = $("#Description").val();

            $.ajax({
                url: '/Subject/Add',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    code: Code,
                    name: Name,
                    creditHours: CreditHours,
                    type: Type,
                    description: Description
                }),
                success: function (res) {
                    alert(res.message);
                    $("#SubjectTable tbody").empty();
                    GetAllSubjects();
                },
                error: function (err) {
                    alert("Insert failed.");
                    console.error(err);
                }
            });
        }

        function GetAllSubjects() {
            $.ajax({
                url: '/Subject/GetAll',
                type: 'GET',
                contentType: 'application/json',
                success: function (res) {
                    const tbody = document.querySelector("#SubjectTable tbody");
                    tbody.innerHTML = "";

                    res.forEach(item => {
                        let row = document.createElement("tr");
                        row.innerHTML = `
                            <td>${item.id}</td>
                            <td>${item.code}</td>
                            <td>${item.name}</td>
                            <td>${item.creditHours}</td>
                            <td>${item.type}</td>
                            <td>${item.description}</td>
                            <td>
                                <button style="background-color:blue;" onclick="getById(${item.id})">Edit</button>
                                <button style="background-color:lightgray;" onclick="DeleteRow(${item.id})">Delete</button>
                            </td>`;
                        tbody.appendChild(row);
                    });
                },
                error: function (err) {
                    alert("Failed to load subjects.");
                    console.error(err);
                }
            });
        }

        function DeleteRow(id) {
            if (!confirm('Are you sure you want to delete this subject?')) {
                return;
            }
            $.ajax({
                url: `/Subject/DeleteRow/${id}`,
                type: 'DELETE',
                success: function (res) {
                    alert(res.message);
                    $("#SubjectTable tbody").empty();
                    GetAllSubjects();
                },
                error: function (err) {
                    alert('Failed to delete subject');
                    console.error(err);
                }
            });
        }

        function getById(id) {
            $.ajax({
                url: '/Subject/EditRow/' + id,
                type: "GET",
                contentType: 'application/json',
                success: function (res) {
                    $("#Id").val(res.id);
                    $("#Code").val(res.code);
                    $("#Name").val(res.name);
                    $("#CreditHours").val(res.creditHours);
                    $("#Type").val(res.type);
                    $("#Description").val(res.description);
                },
                error: function (err) {
                    alert("Failed to fetch subject.");
                    console.error(err);
                }
            });
        }

        function UpdateSubject() {
            var Id = $("#Id").val();
            var Code = $("#Code").val();
            var Name = $("#Name").val();
            var CreditHours = $("#CreditHours").val();
            var Type = $("#Type").val();
            var Description = $("#Description").val();

            $.ajax({
                url: '/Subject/Update',
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({
                    id: Id,
                    code: Code,
                    name: Name,
                    creditHours: CreditHours,
                    type: Type,
                    description: Description
                }),
                success: function (res) {
                    alert(res.message);
                    $("#SubjectTable tbody").empty();
                    GetAllSubjects();

                    // clear fields
                    $("#Id").val("");
                    $("#Code").val("");
                    $("#Name").val("");
                    $("#CreditHours").val("");
                    $("#Type").val("");
                    $("#Description").val("");
                },
                error: function (err) {
                    alert("Update failed.");
                    console.error(err);
                }
            });
        }

        function checkAction() {
            var Id = $("#Id").val();
            if (Id && Id !== "0") {
                UpdateSubject();
            } else {
                AddSubject();
            }
        }

        window.onload = () => GetAllSubjects();
    </script>
</div>
